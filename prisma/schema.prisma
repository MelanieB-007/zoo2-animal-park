generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model tiere {
  id            Int     @id @default(autoincrement())
  release       String? @db.VarChar(10)
  preis         Int?
  preisartId    Int?
  preisart      preisart? @relation(fields: [preisartId], references: [id])
  verkaufswert  Int?
  popularitaet  Int?
  auswildern    Int?
  bild          String? @db.VarChar(255)

  // Gehege (Biome) & Platz
  gehegeId      Int
  gehege        gehege  @relation(fields: [gehegeId], references: [id])
  platzbedarf   Int?
  spielgeraetId Int?

  // Zucht & Stall
  stalllevel    Int?
  zuchtkosten   Int?
  zuchtdauer    Int?
  startprozent  Int?

  // --- NEU: Dynamische Relationen ---
  statue        wettbewerbstatuen?
  texte         tier_texte[]
  tierherkunft  tierherkunft[]
  variants      farbvarianten[]
  tier_gehege_kapazitaet tier_gehege_kapazitaet[]
  xp            xp[]
}

model tier_texte {
  id           Int    @id @default(autoincrement())
  tierId       Int
  tier         tiere  @relation(fields: [tierId], references: [id], onDelete: Cascade)
  spracheCode  String @db.VarChar(5) // z.B. "de", "en"
  name         String @db.VarChar(255)
  beschreibung String? @db.Text

  @@unique([tierId, spracheCode]) // Verhindert doppelte Sprachen pro Tier
}

model sprachen {
  code String @id @db.VarChar(5) // "de", "en", "dk"
  name String @db.VarChar(50) // "Deutsch", "English"
  flagge String? // Optional ein Emoji oder Icon-Pfad
}

model gehege {
  id                       Int     @id @unique(map: "gehegeindex") @default(autoincrement())
  name                     String  @db.VarChar(50)
  nameEn                   String  @db.VarChar(50)
  namegehege               String  @db.VarChar(50)
  namegehegeEn             String  @db.VarChar(50)
  pfad                     String  @db.VarChar(50)
  preis                    Int?
  preisartId               Int?
  kostenvergroesserung     Int?
  preisartvergroesserungId Int?
  platzbedarf              Int?
  hintergrundfarbe         String  @db.VarChar(10)
  schriftfarbe             String  @db.VarChar(10)
  bild                     String? @db.VarChar(255)
  tiere                    tiere[]
}

model akademie {
  id      Int     @id @unique(map: "akademieindex") @default(autoincrement())
  level   String  @db.VarChar(50)
  levelEn String? @db.VarChar(50)
}

model farbvarianten {
  id         Int     @id @unique(map: "farbvariantenindex") @default(autoincrement())
  tierId     Int
  tier       tiere   @relation(fields: [tierId], references: [id], onDelete: Cascade)
  farbe      String  @db.VarChar(20)
  herkunftId Int
  herkunft   herkunft @relation(fields: [herkunftId], references: [id])
  release    String? @db.VarChar(20)
  bild       String? @db.VarChar(255)

  @@index([tierId])
}

model gehegedeko {
  id           Int     @id @unique(map: "gehegedekoindex")
  name         String  @db.VarChar(255)
  name_en      String? @map("name-en") @db.VarChar(255)
  gehege       Int
  preis        Int?
  preisart     Int?
  popularitaet Int?
  platzbedarf  Int?
  bild         String? @db.VarChar(255)
}

model tier_gehege_kapazitaet {
  tierId      Int
  tier        tiere @relation(fields: [tierId], references: [id], onDelete: Cascade)
  anzahlTiere Int
  felder      Int

  @@id([tierId, anzahlTiere])
}

model gehegespielgeraet {
  id                  Int     @id @unique(map: "gehegespielgeraetindex")
  name                String  @db.VarChar(255)
  nameEn              String? @db.VarChar(255)
  gehegeId            Int
  preis               Int?
  preisartId          Int?
  reparatur           Int?
  reparaturpreisartId Int?
  bild                String? @db.VarChar(255)
}

model gehegestall {
  id             Int     @id @unique(map: "gehegestallindex")
  gehege         Int
  preis          Int?
  preisart       Int?
  level1         Int?
  preisartlevel1 Int?
  updatezeit1    Int?
  level2         Int?
  preisartlevel2 Int?
  updatezeit2    Int?
  level3         Int?
  preisartlevel3 Int?
  updatezeit3    Int?
  bild           String? @db.VarChar(255)
}

model gehegetrog {
  id       Int     @id @unique(map: "gehegeTrogindex")
  gehege   Int
  preis    Int?
  preisart Int?
  bild     String? @db.VarChar(255)
}

model gehegewasserstelle {
  id                Int     @id @unique(map: "gehegewasserstelleindex")
  gehege            Int
  preis             Int?
  preisart          Int?
  reparatur         Int?
  reparaturpreisart Int?
  bild              String? @db.VarChar(255)
}

model herkunft {
  id        Int     @id @unique(map: "herkunftindex") @default(autoincrement())
  name      String  @db.VarChar(50)
  nameen    String  @db.VarChar(50)
  nametiere String  @db.VarChar(50)
  bild      String? @db.VarChar(255)

  tierherkunft tierherkunft[]
  variants    farbvarianten[]
}

model klubrollen {
  id     Int     @id @unique(map: "klubrollenindex") @default(autoincrement())
  name   String  @db.VarChar(255)
  nameEn String? @db.VarChar(255)
}

model mitglieder {
  id                Int     @id @unique(map: "id") @default(autoincrement())
  upjersname        String  @db.VarChar(50)
  webseitename      String? @db.VarChar(50)
  webseitenpasswort String  @db.VarChar(100)
  wikiname          String? @db.VarChar(50)
  name              String? @db.VarChar(50)
  upjersid          String? @db.VarChar(10)
  sprache           String? @db.VarChar(20)
  aktiv             String  @db.VarChar(5)
  seit              String? @db.VarChar(20)
  klubstatus        Int
  webseitestatus    Int
  klubrang          Int
  level             Int
  akademie          Int?
}

model mitgliederlevel20 {
  id           Int     @id @unique(map: "mitgliederlevel20index") @default(autoincrement())
  tierId       Int
  mitgliederId Int
  vorhanden    String? @default("0") @db.VarChar(20)
}

model mitgliederrang {
  id                      Int     @id @unique(map: "id") @default(autoincrement())
  name                    String? @db.VarChar(255)
  name_en                 String? @map("name-en") @db.VarChar(255)
  level                   Int
  exp_zum_naechsten_level Int?    @map("exp-zum-naechsten-level")
  bild                    String? @db.VarChar(255)
}

model mitgliederstatuen {
  id           Int  @id @unique(map: "mitgliederstatuenindex") @default(autoincrement())
  statueId     Int
  mitgliederId Int
  puzzleteile  Int? @default(0)
}

model mitgliederwettbewerbfarbvarianten {
  id           Int     @id @unique(map: "mitgliederwettbewerbFarbvariantenindex") @default(autoincrement())
  farbId       Int
  mitgliederId Int
  puzzleteile  String? @default("0") @db.VarChar(20)
}

model preisart {
  id     Int     @id @unique(map: "preisartindex") @default(autoincrement())
  name   String  @db.VarChar(50)
  nameen String? @db.VarChar(50)
  bild   String? @db.VarChar(50)
  tiere  tiere[]
}

model tierherkunft {
  id         Int  @id @unique(map: "herkunftindex") @default(autoincrement())
  tierid     Int
  herkunftId Int?

  tier       tiere     @relation(fields: [tierid], references: [id], onDelete: Cascade)
  herkunft   herkunft? @relation(fields: [herkunftId], references: [id], onDelete: Cascade)

  @@index([tierid])
  @@index([herkunftId])
}

model users {
  id         Int       @unique
  name       String?   @db.VarChar(255)
  email      String?   @unique @db.VarChar(255)
  image      String?   @db.Text
  role       String    @default("Besucher") @db.VarChar(20)
  last_login DateTime? @default(now()) @db.DateTime(0)
}

model wettbewerbe {
  id                 Int     @id @unique(map: "wettbewerbe") @default(autoincrement())
  start              String  @db.VarChar(20)
  ende               String  @db.VarChar(20)
  tier1Id            Int     @unique
  tier2Id            Int     @unique
  tier3Id            Int     @unique
  farbvarianteId     Int?
  aktiv              Int
  tierTeilgenommenId String? @db.VarChar(20)
  ergebnis           String? @db.VarChar(20)
  platz              String? @db.VarChar(255)
}

model wettbewerbfarbvarianten {
  id             Int     @id @unique(map: "wettbewerbfarbvariantenindex") @default(autoincrement())
  tierId         Int     @unique
  farbvarianteId Int     @unique
}

model wettbewerbstatuen {
  id            Int     @id @unique(map: "wettbewerbstatuenindex") @default(autoincrement())
  tierId        Int     @unique
  tier          tiere   @relation(fields: [tierId], references: [id])
  preis         Int?
  preisartId    Int?
  popularitaet  Int?
  verkaufspreis Int?
  bild          String? @db.VarChar(255)
}

model xp {
  id     Int    @id @unique(map: "xpindex") @default(autoincrement())
  tierId Int
  xpart  String @db.VarChar(20)
  wert   Int?
  zeit   Int?
  tier    tiere  @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@index([tierId])
}